<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ pageTitle if pageTitle else "Tanay Mehendale - Portfolio" }}</title>
    <link rel="icon" type="image/x-icon" href="/assets/images/portfolio-logo.png">
    <link rel="stylesheet" href="/assets/css/style.css">
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
    <link rel="preload" href="/assets/images/hero-bg.jpg" as="image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body class="dark-mode">

    <!-- Header -->
    <header>
        <nav>
            <div class="nav-left">
                <img id="nav-logo" src="/assets/images/portfolio-logo.png" alt="Logo" class="nav-logo">
                <span class="nav-name">Tanay Mehendale</span>
            </div>
            <div class="nav-right">
                <ul class="nav-menu">
                    <li><a href="/#about">About</a></li>
                    <li><a href="/#projects">Projects</a></li>
                    <li><a href="/#experience">Experience</a></li>
                    <li><a href="/#education">Education</a></li>
                    <li><a href="/#skills">Skills</a></li>
                    <li><a href="/#contact">Contact</a></li>
                </ul>
                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
                    <i class="fa fa-sun-o"></i>
                </button>
            </div>
        </nav>
    </header>

    {{ content | safe }}

    <!-- Bottom Navigation for Mobile/Tablet -->
    <nav class="bottom-nav">
        <a href="/#about">
            <i class="fa fa-user-o"></i>
            <span>About</span>
        </a>
        <a href="/#projects">
            <i class="fa fa-code"></i>
            <span>Projects</span>
        </a>
        <a href="/#experience">
            <i class="fa fa-briefcase"></i>
            <span>Experience</span>
        </a>
        <a href="/#contact">
            <i class="fa fa-envelope-o"></i>
            <span>Contact</span>
        </a>
        <div class="dropup">
            <button id="more-btn">
                <i class="fa fa-ellipsis-h"></i>
                <span>More</span>
            </button>
            <div id="more-menu" class="dropup-menu">
                <a href="/#education"><i class="fa fa-graduation-cap"></i> Education</a>
                <a href="/#skills"><i class="fa fa-terminal"></i> Skills</a>
            </div>
        </div>
    </nav>

    <div class="floating-buttons">
        <a href="/assets/docs/Tanay Mehendale_Resume_AI.pdf" class="float-button resume-button" target="_blank">
            <i class="fa fa-file-text"></i> View Resume
        </a>
        <a href="#" class="float-button scroll-top">
            <i class="fa fa-chevron-up"></i>
        </a>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="copyright">
                <p>Copyright &copy; 2025 Tanay Mehendale</p>
            </div>
            <div class="back-to-top">
                <a href="#lead">
                    <i class="fa fa-chevron-up"></i>
                </a>
            </div>
            <div class="social">
                <a href="https://github.com/tanaymehendale" target="_blank">
                    <i class="fa fa-github"></i>
                </a>
                <a href="https://linkedin.com/in/tanay-mehendale" target="_blank">
                    <i class="fa fa-linkedin"></i>
                </a>
            </div>
        </div>
    </footer>

    <script src="/emailjs_config.js"></script>
    <script src="/script.js"></script>
</body>
</html>
