<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ pageTitle if pageTitle else "Tanay Mehendale - Portfolio" }}</title>
    <link rel="icon" type="image/x-icon" href="/assets/images/portfolio-logo.png">
    <link rel="stylesheet" href="/assets/css/style.css">
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
    <link rel="preload" href="/assets/images/hero-bg.jpg" as="image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700&family=Bricolage+Grotesque:wght@700;800&family=Hanken+Grotesk:wght@400;500;600&family=Orbitron:wght@400;700&family=Exo+2:ital,wght@0,200;0,300;1,200;1,300&display=swap" rel="stylesheet">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.10.0/mapbox-gl.css" rel="stylesheet">
</head>
<body class="dark-mode">

    <!-- Header -->
    <header>
        <nav>
            <div class="nav-left">
                <a href="/" class="nav-logo-link" aria-label="Tanay Mehendale — Home">
                    <img src="/assets/images/portfolio-logo.png" alt="" class="nav-logo-img nav-logo-default" aria-hidden="true">
                    <img src="/assets/images/portfolio-logo-black.png" alt="" class="nav-logo-img nav-logo-black" aria-hidden="true">
                </a>
            </div>
            <div class="nav-right">
                <ul class="nav-menu">
                    <li><a href="/#about">About</a></li>
                    <li><a href="/#projects">Projects</a></li>
                    <li><a href="/#journey">Journey</a></li>
                    <li><a href="/#skills">Skills</a></li>
                    <li><a href="/#certifications">Certs</a></li>
                    <li><a href="/#contact">Contact</a></li>
                </ul>
                <a href="/assets/docs/Tanay Mehendale_Resume_AI.pdf" class="nav-resume-btn" target="_blank" rel="noreferrer noopener" aria-label="View resume PDF">
                    View Resume <span aria-hidden="true">↗</span>
                </a>
                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark/light theme">
                    <svg class="theme-icon theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                    <svg class="theme-icon theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="5"/>
                        <line x1="12" y1="1" x2="12" y2="3"/>
                        <line x1="12" y1="21" x2="12" y2="23"/>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                        <line x1="1" y1="12" x2="3" y2="12"/>
                        <line x1="21" y1="12" x2="23" y2="12"/>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                </button>
                <button id="nav-hamburger" class="nav-hamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-overlay">
                    <span class="ham-bar"></span>
                    <span class="ham-bar"></span>
                    <span class="ham-bar"></span>
                </button>
            </div>
        </nav>
    </header>

    <!-- Full-screen mobile menu overlay -->
    <div id="nav-overlay" class="nav-overlay" aria-hidden="true" role="dialog" aria-label="Navigation menu">
        <div class="overlay-watermark" aria-hidden="true">TM</div>
        <nav class="overlay-nav" aria-label="Main navigation">
            <a href="/#about" class="overlay-link">
                <span class="overlay-num">01</span>
                <span class="overlay-label">About</span>
            </a>
            <a href="/#projects" class="overlay-link">
                <span class="overlay-num">02</span>
                <span class="overlay-label">Projects</span>
            </a>
            <a href="/#journey" class="overlay-link">
                <span class="overlay-num">03</span>
                <span class="overlay-label">Journey</span>
            </a>
            <a href="/#skills" class="overlay-link">
                <span class="overlay-num">04</span>
                <span class="overlay-label">Skills</span>
            </a>
            <a href="/#certifications" class="overlay-link">
                <span class="overlay-num">05</span>
                <span class="overlay-label">Certs</span>
            </a>
            <a href="/#contact" class="overlay-link">
                <span class="overlay-num">06</span>
                <span class="overlay-label">Contact</span>
            </a>
        </nav>
        <div class="overlay-footer">
            <a href="https://github.com/tanaymehendale" target="_blank" rel="noreferrer" class="overlay-social">GitHub</a>
            <a href="https://linkedin.com/in/tanay-mehendale" target="_blank" rel="noreferrer" class="overlay-social">LinkedIn</a>
            <a href="/assets/docs/Tanay Mehendale_Resume_AI.pdf" target="_blank" rel="noreferrer" class="overlay-social">Resume ↗</a>
        </div>
    </div>

    {{ content | safe }}


    <div class="floating-buttons">
        <a href="#" class="float-button scroll-top">
            <i class="fa fa-chevron-up"></i>
        </a>
    </div>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="sf-inner">

            <!-- Tagline + links -->
            <div class="sf-top">
                <p class="sf-tagline">
                    Built with curiosity,<br>
                    coffee, and too many<br>
                    browser tabs.
                </p>
                <nav class="sf-nav" aria-label="Footer links">
                    <a href="/assets/docs/Tanay Mehendale_Resume_AI.pdf" class="sf-link sf-resume-cta" target="_blank" rel="noreferrer noopener">
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                            <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        View Resume
                    </a>
                    <a href="https://linkedin.com/in/tanay-mehendale" class="sf-link sf-social-cta" target="_blank" rel="noreferrer noopener">
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                            <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        LinkedIn
                    </a>
                    <a href="https://github.com/tanaymehendale" class="sf-link sf-social-cta" target="_blank" rel="noreferrer noopener">
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                            <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        GitHub
                    </a>
                    <a href="#" class="sf-link sf-backtop" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M6 10V2M6 2L2.5 5.5M6 2L9.5 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Back to top
                    </a>
                </nav>
            </div>

            <!-- Visual signature: large outlined name -->
            <div class="sf-signature" aria-hidden="true">
                <span class="sf-name">Tanay Mehendale</span>
            </div>

            <!-- Copyright -->
            <div class="sf-bottom">
                <p class="sf-copy">© 2026 Tanay Mehendale</p>
            </div>

        </div>
    </footer>

    <script src="https://api.mapbox.com/mapbox-gl-js/v3.10.0/mapbox-gl.js"></script>
    <script src="https://unpkg.com/@turf/turf@6.5.0/turf.min.js"></script>
    <script src="/emailjs_config.js"></script>
    <script src="/mapbox_config.js"></script>
    <script src="/script.js"></script>
</body>
</html>
