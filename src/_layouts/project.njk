---
layout: base.njk
---
<div id="pd-progress-bar" class="pd-progress-bar" aria-hidden="true"></div>

<div class="project-detail">

    <!-- Hero -->
    <div class="pd-hero">
        <div class="pd-hero-inner">
            <a href="/#projects" class="pd-breadcrumb">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M9 11L5 7l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Projects
            </a>

            <h1 class="pd-title">{{ project.title }}</h1>

            {% if project.tags %}
            <div class="pd-tags">
                {% for tag in project.tags %}
                <span class="pd-tag">{{ tag }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Two-column layout -->
    <div class="pd-layout">

        <!-- Sidebar -->
        <aside class="pd-sidebar" aria-label="Page navigation">
            <div class="pd-sidebar-sticky">
                {% if project.sections %}
                <nav class="pd-sidenav">
                    <p class="pd-sidenav-label">Contents</p>
                    {% for section in project.sections %}
                    <a class="pd-sidenav-link" href="#pd-s-{{ loop.index }}">
                        <span class="pd-sidenav-num" aria-hidden="true">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                        <span>{{ section.title }}</span>
                    </a>
                    {% endfor %}
                </nav>
                {% endif %}

                {% if project.links.length and not project.isComingSoon %}
                <div class="pd-sidebar-links">
                    {% for link in project.links %}
                    <a href="{{ link.url }}" class="pd-ext-link" target="_blank" rel="noreferrer noopener">
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                            <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        {{ link.label }}
                    </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </aside>

        <!-- Main content -->
        <main class="pd-main">

            {% if project.isAcademicRestricted %}
            <div class="pd-academic-notice">
                <p>Academic work from Texas A&amp;M University — implementation not publicly shareable without explicit professor approval. <a href="/#contact">Get in touch</a> to request access.</p>
            </div>
            {% endif %}

            {% if project.impact %}
            <div class="pd-impact">
                <span class="pd-impact-label">Impact</span>
                <p class="pd-impact-text">{{ project.impact | safe }}</p>
            </div>
            {% endif %}

            <!-- Mobile-only links (shown above sections on small screens) -->
            {% if project.links.length and not project.isComingSoon %}
            <div class="pd-mobile-links">
                {% for link in project.links %}
                <a href="{{ link.url }}" class="pd-cta" target="_blank" rel="noreferrer noopener">
                    {{ link.label }}
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                        <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                {% endfor %}
            </div>
            {% endif %}

            <!-- Coming soon state -->
            {% if project.isComingSoon %}
            <div class="pd-coming-soon">
                <div class="pd-cs-icon">
                    <i class="fa {{ project.comingSoonIcon }}" aria-hidden="true"></i>
                </div>
                <h2 class="pd-cs-callout">{{ project.comingSoonCallout }}</h2>
                <p class="pd-cs-message">{{ project.comingSoonMessage }}</p>

                {% if project.substackEmbed %}
                <div class="substack-post-embed pd-substack">
                    <p lang="en">{{ project.substackTitle }}</p>
                    <p>{{ project.substackDesc }}</p>
                    <a data-post-link href="{{ project.substackUrl }}">Read on Substack</a>
                </div>
                <script async src="https://substack.com/embedjs/embed.js" charset="utf-8"></script>
                {% else %}
                <div class="pd-cs-links">
                    {% for link in project.links %}
                    <a href="{{ link.url }}" class="pd-cta" target="_blank" rel="noreferrer noopener">
                        {{ link.label }}
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                            <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% endif %}

            <!-- Content sections -->
            {% if project.sections %}
            {% for section in project.sections %}
            <section class="pd-section" id="pd-s-{{ loop.index }}">
                <div class="pd-section-hd">
                    <span class="pd-section-num" aria-hidden="true">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                    <h2 class="pd-section-title">{{ section.title }}</h2>
                </div>
                <div class="pd-section-body">
                    {{ section.content | safe }}
                </div>
            </section>
            {% endfor %}
            {% endif %}

            <!-- Bottom actions -->
            <div class="pd-footer-actions">
                {% if project.links.length and not project.isComingSoon %}
                {% for link in project.links %}
                <a href="{{ link.url }}" class="pd-cta" target="_blank" rel="noreferrer noopener">
                    {{ link.label }}
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                        <path d="M1.5 9.5l8-8M9.5 9.5V1.5H1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                {% endfor %}
                {% endif %}
                <a href="/#projects" class="pd-back-home">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M10 6H2M2 6L5.5 2.5M2 6L5.5 9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    All projects
                </a>
            </div>

        </main>
    </div>
</div>

<script>
(function () {
    // ── Reading progress bar ─────────────────────────────────
    var bar = document.getElementById('pd-progress-bar');
    if (bar) {
        function updateBar() {
            var total = document.documentElement.scrollHeight - window.innerHeight;
            bar.style.transform = 'scaleX(' + (total > 0 ? window.scrollY / total : 0) + ')';
        }
        window.addEventListener('scroll', updateBar, { passive: true });
        updateBar();
    }

    // ── Scrollspy ────────────────────────────────────────────
    var navLinks = document.querySelectorAll('.pd-sidenav-link');
    var sections = document.querySelectorAll('.pd-section');
    if (navLinks.length && sections.length) {
        var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    var id = entry.target.id;
                    navLinks.forEach(function (l) {
                        l.classList.toggle('is-active', l.getAttribute('href') === '#' + id);
                    });
                }
            });
        }, { rootMargin: '-15% 0px -70% 0px', threshold: 0 });
        sections.forEach(function (s) { io.observe(s); });
    }

    // ── Sticky sidebar (JS-driven) ───────────────────────────
    // CSS position:sticky is broken when overflow-x:hidden on html/body
    // promotes overflow-y to 'auto', creating a non-viewport scroll container.
    // We replicate sticky with translateY instead.
    var sticky = document.querySelector('.pd-sidebar-sticky');
    var sidebar = document.querySelector('.pd-sidebar');
    if (sticky && sidebar) {
        var OFFSET = 0;
        var sidebarAbsTop = null;

        function computeOffset() {
            var hdr = document.querySelector('header');
            OFFSET = (hdr ? hdr.offsetHeight : 70) + 32; // nav + 2rem
        }

        function cacheSidebarTop() {
            sidebarAbsTop = sidebar.getBoundingClientRect().top + window.pageYOffset;
        }

        function updateSticky() {
            if (sidebarAbsTop === null) return;
            var scrollY = window.pageYOffset;
            var sidebarH = sidebar.offsetHeight;
            var stickyH = sticky.offsetHeight;
            var start = sidebarAbsTop - OFFSET;
            var end   = sidebarAbsTop + sidebarH - OFFSET - stickyH;
            var ty = scrollY <= start ? 0
                   : scrollY >= end  ? Math.max(0, end - start)
                   : scrollY - start;
            sticky.style.transform = 'translateY(' + ty + 'px)';
        }

        function init() {
            computeOffset();
            cacheSidebarTop();
            updateSticky();
        }

        window.addEventListener('scroll', updateSticky, { passive: true });
        window.addEventListener('resize', init, { passive: true });
        window.addEventListener('load', init);
        init();
    }
}());
</script>
