---
layout: base.njk
---
<div class="project-detail">
    <div class="container">

        <!-- Back link -->
        <div class="back-link">
            <a href="/#projects">
                <i class="fa fa-chevron-left"></i> Back
            </a>
        </div>

        <!-- Title -->
        <h1 class="project-title">{{ project.title }}</h1>

        {% if project.isAcademicRestricted %}
        <p><i>Note: This project is part of an academic course at Texas A&amp;M University. I do not have permission to share my implementation without an explicit approval from the professor. To view the project files, please contact me.</i></p>
        {% endif %}

        <!-- Impact / Achievement box -->
        {% if project.impact %}
        <section class="project-section achievement">
            <h2>Impact</h2>
            <div class="achievement-box">
                <p>{{ project.impact | safe }}</p>
            </div>
        </section>
        {% endif %}

        <!-- Coming soon / special display -->
        {% if project.isComingSoon %}
        <div style="margin: 60px 0;">
            <div class="coming-soon-box">
                <i class="fa {{ project.comingSoonIcon }}" style="font-size:2.5em;color:#3498db;"></i>
                <h2 style="margin-top:20px; color:#3498db;">{{ project.comingSoonCallout }}</h2>
                <p style="color:#74808a; margin-top:10px;">{{ project.comingSoonMessage }}</p>

                {% if project.substackEmbed %}
                <div class="substack-post-embed" style="align-items: center; align-content: center;">
                    <p lang="en">{{ project.substackTitle }}</p>
                    <p>{{ project.substackDesc }}</p>
                    <a data-post-link href="{{ project.substackUrl }}">Read on Substack</a>
                </div>
                <script async src="https://substack.com/embedjs/embed.js" charset="utf-8"></script>
                {% else %}
                <div class="project-links">
                    {% for link in project.links %}
                    <a href="{{ link.url }}" class="external-button" target="_blank" rel="noreferrer noopener">
                        <i class="fa {{ link.icon }}"></i> {{ link.label }}
                    </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <!-- Top links (shown before sections for quick access) -->
        {% if project.links.length and not project.isComingSoon %}
        <div class="project-links-top">
            {% for link in project.links %}
            <a href="{{ link.url }}" class="external-button" target="_blank" rel="noreferrer noopener">
                <i class="fa {{ link.icon }}"></i> {{ link.label }}
            </a>
            {% endfor %}
        </div>
        {% endif %}

        <!-- Content sections -->
        {% if project.sections %}
        {% for section in project.sections %}
        <section class="project-section">
            <h2>{{ section.title }}</h2>
            <div class="content">
                {{ section.content | safe }}
            </div>
        </section>
        {% endfor %}
        {% endif %}

        <!-- Bottom links -->
        {% if project.links.length and not project.isComingSoon %}
        <div class="project-links">
            {% for link in project.links %}
            <a href="{{ link.url }}" class="external-button" target="_blank" rel="noreferrer noopener">
                <i class="fa {{ link.icon }}"></i> {{ link.label }}
            </a>
            {% endfor %}
            <a href="/#projects" class="back-button">
                <i class="fa fa-arrow-left"></i> Back to homepage
            </a>
        </div>
        {% endif %}

        {% if project.isComingSoon and not project.substackEmbed %}
        <div class="project-links">
            <a href="/#projects" class="back-button">
                <i class="fa fa-chevron-left"></i> Back to homepage
            </a>
        </div>
        {% endif %}

    </div>
</div>
